{
  "cli": {
    "version": ">= 16.20.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "//": "Renseigner le chemin du JSON du compte de service Google Play une fois le compte créé",
        "track": "internal"
      },
      "ios": {
        "//": "Renseigner appleId, ascAppId et appleTeamId une fois le compte Apple Developer créé"
      }
    }
  }
}
